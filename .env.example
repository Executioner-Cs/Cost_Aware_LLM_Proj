# Copy to `.env` at repo root and fill in values.
# `orchestrator connect <provider>` uses:
#   1) `--api-key` if provided
#   2) `.env` / environment variables
#   3) hidden prompt in the terminal

# Optional: pre-seed API keys (PAT = Personal Access Token)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=...

# Orchestrator config dir (default: ~/.orchestrator)
# ORCHESTRATOR_HOME=~/.orchestrator
