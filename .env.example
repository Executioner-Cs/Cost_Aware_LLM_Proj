# Copy to .env and fill in values
# These are only needed if you want to override auto-discovery via `orchestrator connect`

# Optional: pre-seed API keys (PAT = Personal Access Token)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=...

# Orchestrator config dir (default: ~/.orchestrator)
# ORCHESTRATOR_HOME=~/.orchestrator
